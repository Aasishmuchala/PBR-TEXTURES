# OPTIONAL server-side fallbacks. The app is BYOK — keys are normally entered in
# the Settings page and stored in your browser. These env vars only act as a
# fallback if a request arrives without a key header (handy for local dev).

# fal.ai key (the keystone for PATINA). https://fal.ai/dashboard/keys
FAL_KEY=

# OpenRouter key — only used for the optional "auto-label" feature.
OPENROUTER_API_KEY=
