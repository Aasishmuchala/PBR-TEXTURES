# Copy this file to ".env" and fill in your keys.

# ---- REQUIRED ----
# PATINA is fal-exclusive and is the keystone of the entire pipeline.
# Nothing runs without this. Create one: https://fal.ai/dashboard/keys
FAL_KEY=

# ---- OPTIONAL ----
# Enables --auto-label: names the material straight from the image so you don't
# have to type --material. Create one: https://openrouter.ai/keys
OPENROUTER_API_KEY=
